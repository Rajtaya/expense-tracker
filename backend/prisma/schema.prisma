// ExpenseTracker — Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  icon      String?
  color     String?
  expenses  Expense[]
  createdAt DateTime  @default(now())
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  OTHER
}

enum TxType {
  EXPENSE // money spent
  GIVEN // money given to a person (out)
  RECEIVED // money received from a person (in)
}

model Expense {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          TxType        @default(EXPENSE)
  person        String? // who money was given to / received from
  categoryId    String?
  category      Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  amount        Decimal       @db.Decimal(12, 2)
  description   String?
  paymentMethod PaymentMethod @default(CASH)
  expenseDate   DateTime      @db.Date
  receiptImage  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([expenseDate])
  @@index([type])
}
